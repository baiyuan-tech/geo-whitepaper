# These files exist on `main` for operational reasons but should NOT
# appear in Release source code archives (zip / tar.gz) that GitHub
# generates via `git archive`.
# Docs: https://git-scm.com/docs/gitattributes#_creating_an_archive

# Search engine / webmaster verification files — must be reachable at
# their canonical public URLs (served by GitHub Pages), but have no
# business in a downloadable source archive.
google*.html            export-ignore
*-verification.html     export-ignore
BingSiteAuth.xml        export-ignore
# IndexNow key files follow the pattern <32-hex>.txt at site root.
[a-f0-9]*.txt           export-ignore

# CI / tooling config — not part of the published book
.github/            export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
.markdownlint.jsonc export-ignore
.lycheeignore       export-ignore

# Social / promotional material — internal-facing spec, not part of the book
assets/social/      export-ignore

# Normalize line endings in released archives (avoid CRLF noise).
* text=auto eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.cff text eol=lf
